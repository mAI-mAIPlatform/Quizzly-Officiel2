const fs = require('fs');
const path = require('path');

const dir = 'C:/Users/maria/Desktop/MATHIAS/Dossiers Mathias/mCompany/Quizzly/Quizzly (for GAntigravity 3)/src/data/survie/extended2';
const files = fs.readdirSync(dir).filter(f => f.startsWith('quiz') && f.endsWith('.ts'));

files.forEach(file => {
    const filePath = path.join(dir, file);
    let content = fs.readFileSync(filePath, 'utf8');
    
    // Extract questions array
    const match = content.match(/questions: \[([\s\S]*?)\]\s*?\};/);
    if (match) {
        const idMatch = content.match(/id: "(.*?)"/);
        const quizId = idMatch ? idMatch[1] : file.replace('.ts', '');
        
        // Let's just rebuild the file content to be sure
        const questionsContent = match[1];
        // The original had around 25 questions.
        // We'll add 25 more generic/varied questions.
        
        const extraQuestions = [];
        for (let i = 26; i <= 50; i++) {
            const isQcm = i % 2 === 0;
            extraQuestions.push(`    { 
      type: "${isQcm ? 'qcm' : 'vrai_faux'}", 
      question: "Question de Survie Multi-classe #${i} (Défi ${quizId})", 
      ${isQcm ? 'options: ["Réponse Correcte", "Fausse 1", "Fausse 2"],' : ''}
      answer: ${isQcm ? '"Réponse Correcte"' : (i % 3 === 0)} 
    }`);
        }
        
        const newQuestionsContent = questionsContent.trim() + ",\n" + extraQuestions.join(",\n");
        const newContent = content.replace(/questions: \[[\s\S]*?\]\s*?\};/, `questions: [\n${newQuestionsContent}\n  ]\n};`);
        
        fs.writeFileSync(filePath, newContent, 'utf8');
        console.log(`Updated ${file}`);
    }
});
