// v1.1.0 - Support de l'énoncé de question
"use client";

import { useState, useEffect } from "react";

export default function QuestionRelier({ question, hasAnswered, onValidate }: any) {
  const [leftItems, setLeftItems] = useState<{ id: string; text: string }[]>([]);
  const [rightItems, setRightItems] = useState<{ id: string; text: string }[]>([]);
  
  const [selectedLeft, setSelectedLeft] = useState<string | null>(null);
  const [selectedRight, setSelectedRight] = useState<string | null>(null);
  
  const [connections, setConnections] = useState<{ leftId: string; rightId: string }[]>([]);

  useEffect(() => {
    // Shuffle the items for display
    const pairs = question.pairs || [];
    const lefts = pairs.map((p: any, i: number) => ({ id: `l_${i}`, text: p.left }));
    const rights = pairs.map((p: any, i: number) => ({ id: `r_${i}`, text: p.right }));
    
    setLeftItems(lefts.sort(() => Math.random() - 0.5));
    setRightItems(rights.sort(() => Math.random() - 0.5));
    setConnections([]);
    setSelectedLeft(null);
    setSelectedRight(null);
  }, [question]);

  const handleLeftClick = (id: string) => {
    if (hasAnswered) return;
    // Si déjà connecté, on le déconnecte
    if (connections.find(c => c.leftId === id)) {
      setConnections(prev => prev.filter(c => c.leftId !== id));
      return;
    }
    setSelectedLeft(id === selectedLeft ? null : id);
  };

  const handleRightClick = (id: string) => {
    if (hasAnswered) return;
    // Si déjà connecté, on le déconnecte
    if (connections.find(c => c.rightId === id)) {
      setConnections(prev => prev.filter(c => c.rightId !== id));
      return;
    }
    
    if (selectedLeft) {
      // Create connection
      setConnections(prev => [...prev, { leftId: selectedLeft, rightId: id }]);
      setSelectedLeft(null);
    } else {
      setSelectedRight(id === selectedRight ? null : id);
    }
  };

  // Allow clicking right then left
  useEffect(() => {
    if (selectedLeft && selectedRight && !hasAnswered) {
      setConnections(prev => [...prev, { leftId: selectedLeft, rightId: selectedRight }]);
      setSelectedLeft(null);
      setSelectedRight(null);
    }
  }, [selectedLeft, selectedRight, hasAnswered]);

  const handleValidate = () => {
    if (connections.length < question.pairs.length) return; // Must connect all
    
    // Check if correct
    let correctCount = 0;
    connections.forEach(conn => {
      const leftIndex = parseInt(conn.leftId.split("_")[1]);
      const rightIndex = parseInt(conn.rightId.split("_")[1]);
      if (leftIndex === rightIndex) correctCount++;
    });
    
    onValidate(correctCount === question.pairs.length);
  };

  return (
    <div className="flex flex-col h-full animate-in fade-in slide-in-from-bottom-4 duration-500">
      <div className="glass p-6 md:p-8 rounded-3xl mb-8 relative overflow-hidden">
        <span className="absolute top-4 left-6 text-xs uppercase tracking-widest font-bold opacity-50 bg-foreground/10 px-3 py-1 rounded-full">
          Relier
        </span>
        <h2 className="text-2xl md:text-3xl font-space font-bold mt-6 leading-tight">
          {question.enonce || question.question}
        </h2>
      </div>

      <div className="flex-1 flex flex-col md:flex-row gap-4 md:gap-12 relative items-center justify-center max-w-2xl mx-auto w-full">
        {/* Left Column */}
        <div className="flex flex-col gap-4 w-full md:w-1/2">
          {leftItems.map(item => {
            const isConnected = connections.find(c => c.leftId === item.id);
            let stateClass = "glass hover:bg-foreground/5";
            
            if (hasAnswered) {
               const connectedTo = connections.find(c => c.leftId === item.id)?.rightId;
               const rightAnswerId = `r_${item.id.split('_')[1]}`;
               if (connectedTo === rightAnswerId) stateClass = "bg-green text-green-950 border-green/50";
               else stateClass = "bg-rose text-rose-950 border-rose/50";
            } else if (selectedLeft === item.id) {
               stateClass = "bg-primary text-primary-foreground scale-105 shadow-xl shadow-primary/20";
            } else if (isConnected) {
               stateClass = "bg-primary/20 border-primary/50 text-primary opacity-80";
            }

            return (
              <button
                key={item.id}
                onClick={() => handleLeftClick(item.id)}
                className={`p-4 rounded-2xl font-bold transition-all text-center border-2 border-transparent ${stateClass}`}
                disabled={hasAnswered}
              >
                {item.text}
              </button>
            );
          })}
        </div>

        {/* Right Column */}
        <div className="flex flex-col gap-4 w-full md:w-1/2">
          {rightItems.map(item => {
            const isConnected = connections.find(c => c.rightId === item.id);
            let stateClass = "glass hover:bg-foreground/5";
            
            if (hasAnswered) {
               const connectedFrom = connections.find(c => c.rightId === item.id)?.leftId;
               const correctLeftId = `l_${item.id.split('_')[1]}`;
               if (connectedFrom === correctLeftId) stateClass = "bg-green text-green-950 border-green/50";
               else stateClass = "bg-rose text-rose-950 border-rose/50";
            } else if (selectedRight === item.id) {
               stateClass = "bg-primary text-primary-foreground scale-105 shadow-xl shadow-primary/20";
            } else if (isConnected) {
               stateClass = "bg-primary/20 border-primary/50 text-primary opacity-80";
            }

            return (
              <button
                key={item.id}
                onClick={() => handleRightClick(item.id)}
                className={`p-4 rounded-2xl font-bold transition-all text-center border-2 border-transparent ${stateClass}`}
                disabled={hasAnswered}
              >
                {item.text}
              </button>
            );
          })}
        </div>
      </div>

      {!hasAnswered && (
        <button
          onClick={handleValidate}
          disabled={connections.length < (question.pairs?.length || 0)}
          className={`mt-12 w-full md:w-auto md:mx-auto px-12 py-4 rounded-2xl font-bold font-space text-lg transition-all ${
            connections.length === (question.pairs?.length || 0)
              ? "bg-primary text-primary-foreground hover:scale-105 shadow-xl shadow-primary/30 cursor-pointer" 
              : "bg-foreground/10 text-foreground/40 cursor-not-allowed"
          }`}
        >
          Valider
        </button>
      )}
    </div>
  );
}
