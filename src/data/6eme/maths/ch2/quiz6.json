{"id":"quiz6","titre":"Encadrement d'une fraction","questions":[{"id":"q1","type":"qcm","enonce":"La fraction 4/3 est comprise entre quels nombres entiers ?","options":["0 et 1","1 et 2","2 et 3","3 et 4"],"correctIndex":1},{"id":"q2","type":"vrai_faux","enonce":"Toute fraction dont le numérateur est plus petit que le dénominateur est comprise entre 0 et 1.","reponse":true},{"id":"q3","type":"trous","enonce":"La fraction 7/5 est comprise entre 1 et {{1}}.","reponsesAttendues":["2"]},{"id":"q4","type":"qcm","enonce":"Entre quels entiers encadrer 10/3 ?","options":["2 et 3","3 et 4","10 et 11"],"correctIndex":1},{"id":"q5","type":"vrai_faux","enonce":"Pour 12/4, l'encadrement strict est 2 < 12/4 < 4. Mais 12/4 est exactement égal à 3.","reponse":true},{"id":"q6","type":"trous","enonce":"La fraction 1/2 est comprise entre {{1}} et 1.","reponsesAttendues":["0","zero","zéro"]},{"id":"q7","type":"qcm","enonce":"Où se situe 9/8 ?","options":["Entre 0 et 1","Entre 1 et 2","Entre 8 et 9"],"correctIndex":1},{"id":"q8","type":"vrai_faux","enonce":"8/8 est compris strictement entre 1 et 2 (c'est-à-dire 1 < 8/8 < 2).","reponse":false},{"id":"q9","type":"trous","enonce":"15/7 est égal à 2 + 1/7. Ce nombre est donc compris entre 2 et {{1}}.","reponsesAttendues":["3"]},{"id":"q10","type":"qcm","enonce":"La fraction 100/99 est...","options":["Plus petite que 1","Plus grande que 1","Egale à 1"],"correctIndex":1}]}