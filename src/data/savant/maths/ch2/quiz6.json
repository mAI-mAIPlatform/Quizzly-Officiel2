{"id":"quiz6","titre":"Opérations sur les dérivées","questions":[{"id":"q1","type":"qcm","enonce":"Lalquelle est la dérivée d'un produit (uv)' ?","options":["u'v'","u'v + uv'","u' + v'","u'v - uv'"],"correctIndex":1},{"id":"q2","type":"vrai_faux","enonce":"La dérivée de 1/v est -v'/v².","reponse":true},{"id":"q3","type":"trous","enonce":"La dérivée d'un quotient (u/v)' est (u'v - uv') / {{1}}.","reponsesAttendues":["v² / v^2"]},{"id":"q4","type":"relier","question":"Associe (k constant).","pairs":[{"left":"(u+v)'","right":"u' + v'"},{"left":"(ku)'","right":"k * u'"},{"left":"(u²)'","right":"2 * u * u'"}]},{"id":"q5","type":"qcm","enonce":"Dérivée de f(x) = x * sin(x) ?","options":["cos(x)","sin(x) + x*cos(x)","sin(x) - x*cos(x)","x*cos(x)"],"correctIndex":1}]}