{"id":"quiz1","titre":"Développer une expression","questions":[{"id":"q1","type":"qcm","enonce":"Développer 3(x + 2) :","options":["3x + 2","3x + 5","3x + 6","x + 6"],"correctIndex":2},{"id":"q2","type":"vrai_faux","enonce":"Développer une expression, c'est transformer un produit en une somme ou une différence.","reponse":true},{"id":"q3","type":"trous","enonce":"Le développement de x(x - 5) est x^2 - {{1}}x.","reponsesAttendues":["5"]},{"id":"q4","type":"relier","question":"Associe l'expression à son développement.","pairs":[{"left":"2(x - 4)","right":"2x - 8"},{"left":"(x + 1)(x + 2)","right":"x^2 + 3x + 2"},{"left":"-3(2x + 1)","right":"-6x - 3"}]},{"id":"q5","type":"qcm","enonce":"Développer (x + 3)(x - 2) :","options":["x^2 - 6","x^2 + x - 6","x^2 - x - 6","2x + 1"],"correctIndex":1}]}