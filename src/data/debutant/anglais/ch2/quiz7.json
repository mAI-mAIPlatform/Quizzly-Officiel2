{"id":"quiz7","titre":"Present Simple: Negative","questions":[{"id":"q1","type":"qcm","enonce":"How do you say 'Je n'aime pas'?","options":["I not like","I don't like","I doesn't like","I no like"],"correctIndex":1},{"id":"q2","type":"vrai_faux","enonce":"For 'He', we use 'doesn't' for the negative.","reponse":true},{"id":"q3","type":"trous","enonce":"She {{1}} speak Spanish.","reponsesAttendues":["doesn't","does not"]},{"id":"q4","type":"relier","question":"Match the subject to the negative auxiliary.","pairs":[{"left":"I / You / We / They","right":"Don't"},{"left":"He / She / It","right":"Doesn't"}]},{"id":"q5","type":"qcm","enonce":"After 'doesn't', the verb...","options":["Takes an -S","Has no -S (base form)","Takes -ING","Takes -ED"],"correctIndex":1}]}