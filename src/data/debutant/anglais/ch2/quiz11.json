      ]
    },
    {
      "id": "q4",
      "type": "qcm",
      "enonce": "Que signifie 'their' ?",
      "options": [
        "Leur / leurs",
        "Notre / nos",
        "Votre / vos",
        "Son / ses"
      ],
      "correctIndex": 0
    },
    {
      "id": "q5",
      "type": "vrai_faux",
      "enonce": " 'Our' signifie notre ou nos.",
      "reponse": true
    },
    {
      "id": "q6",
      "type": "qcm",
      "enonce": "Comment dit-on 'son' (pour une chose ou un animal) ?",
      "options": [
        "its",
        "it's",
        "his",
        "her"
      ],
      "correctIndex": 0
    },
    {
      "id": "q7",
      "type": "trous",
      "enonce": " 'Leur livre' se dit '{{1}} book' (their).",
