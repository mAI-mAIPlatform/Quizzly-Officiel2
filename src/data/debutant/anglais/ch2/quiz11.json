      "correctIndex": 0
    },
    {
      "id": "q2",
      "type": "vrai_faux",
      "enonce": " 'His' s'utilise pour un homme et 'her' pour une femme.",
      "reponse": true
    },
    {
      "id": "q3",
      "type": "trous",
      "enonce": " 'Ton' se dit '{{1}}' (your).",
