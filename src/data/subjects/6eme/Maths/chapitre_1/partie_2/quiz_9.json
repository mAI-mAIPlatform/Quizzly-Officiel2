  "titre": "Calculer sur les durées",
  "questions": [
    {
      "id": "q1",
      "question": "Combien y a-t-il de minutes dans 2 heures ?",
      "type": "QCM",
      "options": ["100 min", "120 min", "60 min", "200 min"],
      "bonne_reponse": "120 min",
      "explication": "1h = 60 min. Donc 2h = 2 x 60 = 120 min."
    },
    {
      "id": "q2",
      "question": "Une séance commence à 14h30 et finit à 15h45. Quelle est sa durée ?",
      "type": "QCM",
      "options": ["1h00", "1h15", "1h30", "0h45"],
      "bonne_reponse": "1h15",
      "explication": "De 14h30 à 15h30 il y a 1h. De 15h30 à 15h45 il y a 15 min. Total = 1h15."
    },
    {
      "id": "q3",
      "question": "Vrai ou Faux : 200 secondes, c'est plus de 3 minutes.",
      "type": "Vrai/Faux",
      "options": ["Vrai", "Faux"],
      "bonne_reponse": "Vrai",
      "explication": "3 min = 3 x 60 = 180 secondes. 200 > 180."
    },
    {
      "id": "q4",
      "question": "Combien d'heures y a-t-il dans 3 jours ?",
      "type": "QCM",
      "options": ["24", "48", "72", "60"],
      "bonne_reponse": "72",
      "explication": "1 jour = 24h. 3 jours = 3 x 24 = 72h."
    },
    {
      "id": "q5",
      "question": "Vrai ou Faux : Une demi-heure, c'est 30 minutes.",
      "type": "Vrai/Faux",
      "options": ["Vrai", "Faux"],
      "bonne_reponse": "Vrai",
      "explication": "60 / 2 = 30."
    }
  ]
