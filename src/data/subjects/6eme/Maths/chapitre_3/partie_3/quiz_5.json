      "id": "q3",
      "question": "Vrai ou Faux : 1,5 heure est égal à 1 heure level 50 minutes.",
      "type": "Vrai/Faux",
      "options": ["Vrai", "Faux"],
      "bonne_reponse": "Faux",
      "explication": "1,5 h = 1h + 0,5 h = 1h30."
    },
