      "id": "q2",
      "question": "Combien de secondes y a-t-il dans 2 minutes level 15 secondes ?",
      "type": "QCM",
      "options": ["135 s", "115 s", "75 s", "215 s"],
      "bonne_reponse": "135 s",
      "explication": "(2 x 60) + 15 = 120 + 15 = 135 s."
    },
