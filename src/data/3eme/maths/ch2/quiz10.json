{"id":"quiz10","titre":"Révisions Calcul littéral","questions":[{"id":"q1","type":"qcm","enonce":"Quelle est la forme développée de (x - 2)^2 ?","options":["x^2 - 4","x^2 + 4","x^2 - 4x + 4","x^2 - 2x + 4"],"correctIndex":2},{"id":"q2","type":"vrai_faux","enonce":"L'expression x^2 + 1 peut être factorisée avec les identités remarquables apprises en 3ème.","reponse":false},{"id":"q3","type":"trous","enonce":"La solution positive de l'équation x^2 = 16 est {{1}}.","reponsesAttendues":["4"]},{"id":"q4","type":"relier","question":"Associe l'expression.","pairs":[{"left":"(x+2)(x-2)","right":"x^2 - 4"},{"left":"(x+2)^2","right":"x^2 + 4x + 4"},{"left":"x(x-2)","right":"x^2 - 2x"}]},{"id":"q5","type":"qcm","enonce":"Résoudre 2(x + 1) = 10 :","options":["x = 9","x = 4","x = 5","x = 8"],"correctIndex":1}]}